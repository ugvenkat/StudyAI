import os
import pyodbc
from mcp.server.fastmcp import FastMCP
from dotenv import load_dotenv

# Load environment variables
load_dotenv()

mcp = FastMCP("employee")

def get_connection():
    conn_str = (
        f"DRIVER={{{os.getenv('DB_DRIVER')}}};"
        f"SERVER={os.getenv('DB_SERVER')};"
        f"DATABASE={os.getenv('DB_NAME')};"
        f"UID={os.getenv('DB_USER')};"
        f"PWD={os.getenv('DB_PASSWORD')};"
    )
    return pyodbc.connect(conn_str)

# READ - Get all employees
@mcp.tool()
def get_all_employees() -> str:
    """Get all employees from the database."""
    try:
        conn = get_connection()
        cursor = conn.cursor()
        cursor.execute("SELECT id, name, salary FROM Employee")
        rows = cursor.fetchall()
        conn.close()
        if not rows:
            return "No employees found."
        result = "Employees:\n"
        for row in rows:
            result += f"ID: {row[0]}, Name: {row[1]}, Salary: ${row[2]:,.2f}\n"
        return result
    except Exception as e:
        return f"Error: {str(e)}"

# READ - Get employee by ID
@mcp.tool()
def get_employee_by_id(employee_id: int) -> str:
    """Get a specific employee by their ID.
    Args:
        employee_id: The ID of the employee
    """
    try:
        conn = get_connection()
        cursor = conn.cursor()
        cursor.execute("SELECT id, name, salary FROM Employee WHERE id = ?", employee_id)
        row = cursor.fetchone()
        conn.close()
        if not row:
            return f"No employee found with ID {employee_id}."
        return f"ID: {row[0]}, Name: {row[1]}, Salary: ${row[2]:,.2f}"
    except Exception as e:
        return f"Error: {str(e)}"

# CREATE - Add new employee
@mcp.tool()
def add_employee(name: str, salary: float) -> str:
    """Add a new employee to the database.
    Args:
        name: Full name of the employee
        salary: Salary of the employee
    """
    try:
        conn = get_connection()
        cursor = conn.cursor()
        cursor.execute("INSERT INTO Employee (name, salary) VALUES (?, ?)", name, salary)
        conn.commit()
        conn.close()
        return f"Employee '{name}' added successfully with salary ${salary:,.2f}"
    except Exception as e:
        return f"Error: {str(e)}"

# UPDATE - Update employee salary
@mcp.tool()
def update_employee_salary(employee_id: int, new_salary: float) -> str:
    """Update the salary of an existing employee.
    Args:
        employee_id: The ID of the employee to update
        new_salary: The new salary amount
    """
    try:
        conn = get_connection()
        cursor = conn.cursor()
        cursor.execute("UPDATE Employee SET salary = ? WHERE id = ?", new_salary, employee_id)
        if cursor.rowcount == 0:
            return f"No employee found with ID {employee_id}."
        conn.commit()
        conn.close()
        return f"Employee ID {employee_id} salary updated to ${new_salary:,.2f}"
    except Exception as e:
        return f"Error: {str(e)}"

